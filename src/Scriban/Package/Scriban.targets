<Project>
  <PropertyGroup Condition="'$(PackageScribanIncludeSource)' == 'true'">
    <DefineConstants>$(DefineConstants);SCRIBAN_NO_SYSTEM_TEXT_JSON;SCRIBAN_SOURCE_INCLUDE</DefineConstants>
  </PropertyGroup>
  <ItemGroup Condition="'$(PackageScribanIncludeSource)' == 'true'">
    <EditorConfigFiles Include="$(MSBuildThisFileDirectory)../src/Scriban/.editorconfig" />
    <Compile Include="$(MSBuildThisFileDirectory)../src/**/*.cs" Visible="false"/>
  </ItemGroup>
</Project>
